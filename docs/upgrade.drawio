<mxfile host="draw.io">
  <diagram name="Upgrade" id="upgrade">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="t1" value="UPGRADE DE PLANO" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fillColor=#1a1a2e;fontColor=#FFFFFF;rounded=1;strokeColor=#16213e;spacingTop=8;spacingBottom=8;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="700" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t1b" value="Mudanca para plano mais caro - credito do que ja pagou vai pro novo contrato" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="400" y="72" width="800" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1" value="1. CALCULAR CREDITO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="250" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s1d" value="Credito = tudo que o formando ja pagou&#xa;no contrato atual&#xa;&#xa;Exemplo:&#xa;  Plano atual: R$8.000&#xa;  Pagou 4 parcelas de R$400&#xa;  Credito = R$1.600" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="300" height="160" as="geometry"/>
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2" value="2. ABATER NA ENTRADA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6b800;fontColor=#000000;strokeColor=#B09500;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="250" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s2d" value="Entrada do novo plano = 10% do valor&#xa;&#xa;Plano novo: R$12.000&#xa;Entrada = 10% x R$12.000 = R$1.200&#xa;&#xa;Credito (R$1.600) cobre toda a entrada&#xa;&#xa;Entrada a pagar: R$0&#xa;Credito restante: R$1.600 - R$1.200&#xa;                = R$400" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="190" width="300" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="a12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="s3" value="3. ABATER NAS PARCELAS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#60a917;fontColor=#ffffff;strokeColor=#2D7600;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="720" y="130" width="250" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s3d" value="Credito restante (R$400) abate&#xa;do valor a parcelar&#xa;&#xa;Valor parcelado = R$12.000 - R$1.200&#xa;               = R$10.800&#xa;&#xa;Abatimento = R$10.800 - R$400&#xa;           = R$10.400&#xa;&#xa;Parcela = R$10.400 / 12&#xa;        = R$866,67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="190" width="300" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="a23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="s4" value="4. RESULTADO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a4286a;fontColor=#ffffff;strokeColor=#740037;fontSize=14;fontStyle=1;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="1060" y="130" width="250" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s4d" value="Novo contrato:&#xa;  Plano: R$12.000&#xa;  Entrada paga: R$0 (coberta pelo credito)&#xa;  12 parcelas de R$866,67&#xa;  Credito excedente: R$0&#xa;&#xa;Formando so paga a diferenca&#xa;entre os planos, descontando&#xa;o que ja tinha pago antes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="190" width="300" height="190" as="geometry"/>
