        <mxCell id="p4" value="Abr/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="225" y="170" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="Mai/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="170" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="Jun/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="355" y="170" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="p7" value="Jul/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="170" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="p8" value="Ago/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="485" y="170" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="p9" value="Set/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="170" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="p10" value="Out/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="615" y="170" width="60" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="pdots" value="... + 14&#xa;parcelas&#xa;pendentes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="700" y="170" width="65" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="leg1" value="10 pagas x R$500 = R$5.000 (este e o CREDITO)  |  14 pendentes = R$7.000 (canceladas)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="220" width="750" height="20" as="geometry"/>
        </mxCell>

        <!-- NOVO PLANO -->
        <mxCell id="cs2" value="NOVO PLANO (downgrade)" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fillColor=#60a917;fontColor=#FFFFFF;rounded=1;strokeColor=#2D7600;" vertex="1" parent="1">
          <mxGeometry x="950" y="135" width="400" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="np" value="Plano Prata R$8.000&#xa;Entrada: 10% = R$800&#xa;Parcelas: 12x" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="950" y="170" width="220" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="cred" value="CREDITO = R$5.000&#xa;(tudo que ja pagou)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#d6b656;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1200" y="170" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="diff" value="Diferenca entre planos:&#xa;R$8.000 - R$12.000 = -R$4.000&#xa;(plano mais barato)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#7986CB;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1430" y="165" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- PASSO 1 -->
        <mxCell id="st1" value="PASSO 1: CALCULAR CREDITO DO FORMANDO" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#0050ef;fontColor=#FFFFFF;rounded=1;strokeColor=#001DBC;" vertex="1" parent="1">
          <mxGeometry x="30" y="260" width="840" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d1" value="FORMULA:&#xa;  Credito = soma de todas as parcelas ja pagas no contrato atual&#xa;&#xa;  Parcelas pagas: 10 (Jan a Out de 2025)&#xa;  Valor de cada: R$500&#xa;&#xa;  Credito = 10 x R$500 = R$5.000&#xa;&#xa;  As 14 parcelas pendentes do contrato atual sao canceladas.&#xa;  O credito de R$5.000 sera usado no novo contrato." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="295" width="840" height="190" as="geometry"/>
        </mxCell>

        <!-- PASSO 2 -->
        <mxCell id="st2" value="PASSO 2: ABATER CREDITO NA ENTRADA DO NOVO PLANO" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#e6b800;fontColor=#000000;rounded=1;strokeColor=#B09500;" vertex="1" parent="1">
          <mxGeometry x="890" y="260" width="880" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d2" value="FORMULA:&#xa;  Entrada original = Valor novo plano x (Percentual entrada / 100)&#xa;  Entrada original = R$8.000 x (10 / 100) = R$800&#xa;&#xa;  O credito (R$5.000) e MAIOR que a entrada (R$800)?&#xa;  SIM! Credito cobre toda a entrada.&#xa;&#xa;  Credito na entrada = R$800 (absorve a entrada inteira)&#xa;  Entrada a pagar    = R$800 - R$800 = R$0 (formando nao paga entrada!)&#xa;  Credito restante   = R$5.000 - R$800 = R$4.200 (sobrou bastante!)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="890" y="295" width="880" height="190" as="geometry"/>
        </mxCell>

        <!-- PASSO 3 -->
        <mxCell id="st3" value="PASSO 3: ABATER CREDITO RESTANTE NAS PARCELAS" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#60a917;fontColor=#FFFFFF;rounded=1;strokeColor=#2D7600;" vertex="1" parent="1">
          <mxGeometry x="30" y="510" width="840" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d3" value="FORMULA:&#xa;  Valor parcelado = Valor novo plano - Entrada original&#xa;  Valor parcelado = R$8.000 - R$800 = R$7.200&#xa;&#xa;  Credito restante (R$4.200) abate do valor parcelado:&#xa;  Valor a financiar = R$7.200 - R$4.200 = R$3.000&#xa;&#xa;  Valor de cada parcela = Valor a financiar / Numero de parcelas&#xa;  Valor de cada parcela = R$3.000 / 12 = R$250,00&#xa;&#xa;  Credito excedente = R$0&#xa;  (todo credito foi absorvido pela entrada + parcelas)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="545" width="840" height="210" as="geometry"/>
        </mxCell>

        <!-- PASSO 4 -->
        <mxCell id="st4" value="PASSO 4: VERIFICAR EXCEDENTE (caso especial do downgrade)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#a4286a;fontColor=#ffffff;rounded=1;strokeColor=#740037;" vertex="1" parent="1">
          <mxGeometry x="890" y="510" width="880" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d4" value="Se o credito for MAIOR que o valor total do novo plano,&#xa;o formando tem credito excedente (a empresa deve devolver).&#xa;&#xa;NESTE CENARIO (credito R$5.000, plano R$8.000):&#xa;  Credito R$5.000 &lt; Plano R$8.000&#xa;  Excedente = R$0 (sem sobra)&#xa;  Parcela mensal = R$250&#xa;&#xa;CENARIO 2 (se o plano fosse R$4.000):&#xa;  Credito R$5.000 &gt; Plano R$4.000&#xa;  Excedente = R$5.000 - R$4.000 = R$1.000&#xa;  A empresa DEVOLVE R$1.000 ao formando!&#xa;  Parcela mensal = R$0 (contrato ja quitado pelo credito)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="890" y="545" width="880" height="240" as="geometry"/>
        </mxCell>

        <!-- RESULTADO -->
        <mxCell id="res1" value="RESULTADO CENARIO 1 (plano R$8.000)&#xa;&#xa;  Credito = R$5.000 (10 parcelas pagas)       PASSOU&#xa;  Entrada a pagar = R$0                        PASSOU&#xa;  Credito nas parcelas = R$4.200               PASSOU&#xa;  12 parcelas de R$250,00                      PASSOU&#xa;  Excedente = R$0                              PASSOU" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="780" width="500" height="155" as="geometry"/>
        </mxCell>

        <mxCell id="res2" value="RESULTADO CENARIO 2 (plano R$4.000)&#xa;&#xa;  Credito = R$5.000                            PASSOU&#xa;  Excedente = R$1.000 (devolver!)              PASSOU&#xa;  Parcela mensal = R$0 (quitado!)              PASSOU" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="780" width="500" height="120" as="geometry"/>
        </mxCell>

        <!-- BROWSER -->
        <mxCell id="bf" value="FLUXO NO PORTAL" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fillColor=#1a1a2e;fontColor=#FFFFFF;rounded=1;strokeColor=#16213e;" vertex="1" parent="1">
          <mxGeometry x="30" y="960" width="1740" height="25" as="geometry"/>
        </mxCell>
