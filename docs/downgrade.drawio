        <mxCell id="cs1" value="CONTRATO ATUAL (vai ser cancelado)" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;fillColor=#b85450;fontColor=#FFFFFF;rounded=1;strokeColor=#943634;" vertex="1" parent="1">
          <mxGeometry x="30" y="100" width="1740" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="c1" value="Contrato #67890  |  Plano Ouro R$12.000  |  24x de R$500  |  Inicio Jan/2025" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#b85450;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="135" width="900" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="Jan/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="1">
