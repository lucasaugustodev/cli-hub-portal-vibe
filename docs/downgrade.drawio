          <mxGeometry x="140" y="995" width="90" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="b3" value="3. Acoes >&#xa;Downgrade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="995" width="105" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="b4" value="4. Escolher&#xa;plano menor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="375" y="995" width="100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="b5" value="5. Parcelas&#xa;(sliders)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="495" y="995" width="100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="b6" value="6. Confirmar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="615" y="995" width="90" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="b7" value="7. Sucesso" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="725" y="995" width="90" height="30" as="geometry"/>
        </mxCell>
