        <mxCell id="b4" value="4. Formulario&#xa;(sliders)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1250" y="935" width="110" height="35" as="geometry"/>
