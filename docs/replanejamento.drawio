          <mxGeometry x="190" y="175" width="75" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="Dez/25&#xa;R$500&#xa;PAGO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="175" width="75" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="Jan/26&#xa;R$500&#xa;VENCIDA&#xa;90 dias" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="175" width="80" height="50" as="geometry"/>
