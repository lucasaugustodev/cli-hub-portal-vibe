        <mxCell id="c1" value="Contrato #12345  |  Turma FORMAE-99999  |  Plano Ouro R$6.000  |  12x de R$500  |  Vencimento dia 10  |  Inicio Set/2025" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#7986CB;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="135" width="1100" height="30" as="geometry"/>
