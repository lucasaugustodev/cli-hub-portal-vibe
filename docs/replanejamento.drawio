        <mxCell id="b3" value="3. Acoes >&#xa;Replanejamento" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="935" width="115" height="35" as="geometry"/>
