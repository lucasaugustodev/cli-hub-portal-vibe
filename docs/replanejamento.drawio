          <mxGeometry x="455" y="175" width="80" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p7" value="Mar/26&#xa;R$500&#xa;VENCIDA&#xa;30 dias" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="175" width="80" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p8" value="Abr/26&#xa;R$500&#xa;FUTURA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="645" y="175" width="70" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p9" value="Mai/26&#xa;R$500&#xa;FUTURA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="175" width="70" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p10" value="Jun/26&#xa;R$500&#xa;FUTURA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="795" y="175" width="70" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p11" value="Jul/26&#xa;R$500&#xa;FUTURA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="175" width="70" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p12" value="Ago/26&#xa;R$500&#xa;FUTURA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="945" y="175" width="70" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="leg" value="4 pagas = R$2.000  |  3 vencidas = R$1.500  |  5 futuras = R$2.500  |  Pendente total = R$4.000  |  Data referencia: 10/03/2026" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="30" y="230" width="1000" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="sum" value="Resumo&#xa;Ja pagou: 4 x R$500 = R$2.000&#xa;Vencidas: 3 x R$500 = R$1.500&#xa;Futuras:  5 x R$500 = R$2.500&#xa;Pendente: R$4.000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#7986CB;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1150" y="135" width="230" height="95" as="geometry"/>
        </mxCell>

        <mxCell id="cfg" value="Config de encargos:&#xa;Multa: 2% (fixa)&#xa;Juros: 1% ao mes&#xa;Tipo: SIMPLES&#xa;Entrada min: 10%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#7986CB;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1400" y="135" width="200" height="95" as="geometry"/>
        </mxCell>

        <!-- PASSO 1 -->
        <mxCell id="st1" value="PASSO 1: DECOMPOR PRINCIPAL" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#e6b800;fontColor=#000000;rounded=1;strokeColor=#B09500;" vertex="1" parent="1">
          <mxGeometry x="30" y="270" width="840" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d1" value="Separar parcelas pendentes em 4 grupos:&#xa;&#xa;  Mensal Vencido  = parcelas normais atrasadas        = 3 x R$500 = R$1.500&#xa;  AA Vencida      = arrecadacao alternativa atrasada   = R$0 (nao tem)&#xa;  Mensal Futuro   = parcelas normais a vencer          = 5 x R$500 = R$2.500&#xa;  AA Futura       = arrecadacao alternativa a vencer    = R$0 (nao tem)&#xa;&#xa;  Principal Vencido = Mensal Vencido + AA Vencida = R$1.500 + R$0 = R$1.500&#xa;  Principal Total   = tudo pendente = R$1.500 + R$2.500 = R$4.000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="305" width="840" height="180" as="geometry"/>
        </mxCell>

        <!-- PASSO 2 -->
        <mxCell id="st2" value="PASSO 2: CALCULAR ENCARGOS (TAXA DE RENEGOCIACAO)" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#e6b800;fontColor=#000000;rounded=1;strokeColor=#B09500;" vertex="1" parent="1">
          <mxGeometry x="890" y="270" width="880" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d2" value="Para cada parcela VENCIDA, cobrar multa + juros:&#xa;&#xa;  FORMULA MULTA:  Multa = Valor x (Percentual / 100)&#xa;                 Multa = R$500 x 0,02 = R$10,00 (igual pra todas)&#xa;&#xa;  FORMULA JUROS:  Juros = Valor x (Taxa/100) x (Dias / 30)&#xa;&#xa;  Jan/26 (90 dias atrasada):&#xa;    Juros = R$500 x 0,01 x (90/30) = R$500 x 0,01 x 3 = R$15,00&#xa;    Encargo desta parcela = R$10 + R$15 = R$25,00&#xa;&#xa;  Fev/26 (60 dias atrasada):&#xa;    Juros = R$500 x 0,01 x (60/30) = R$500 x 0,01 x 2 = R$10,00&#xa;    Encargo desta parcela = R$10 + R$10 = R$20,00&#xa;&#xa;  Mar/26 (30 dias atrasada):&#xa;    Juros = R$500 x 0,01 x (30/30) = R$500 x 0,01 x 1 = R$5,00&#xa;    Encargo desta parcela = R$10 + R$5 = R$15,00&#xa;&#xa;  TAXA TOTAL DE RENEGOCIACAO = R$25 + R$20 + R$15 = R$60,00" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="890" y="305" width="880" height="350" as="geometry"/>
        </mxCell>

        <!-- PASSO 3 -->
        <mxCell id="st3" value="PASSO 3: CALCULAR ENTRADA INTELIGENTE" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#60a917;fontColor=#FFFFFF;rounded=1;strokeColor=#2D7600;" vertex="1" parent="1">
          <mxGeometry x="30" y="510" width="840" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d3" value="A entrada e o MAIOR entre duas opcoes:&#xa;&#xa;  Opcao A = 10% do principal vencido&#xa;          = 10% x R$1.500 = R$150,00&#xa;&#xa;  Opcao B = valor de 1 parcela do novo plano&#xa;          = Principal Total / Numero de Parcelas&#xa;          = R$4.000 / 12 = R$333,33&#xa;&#xa;  FORMULA:  Entrada = MAX(Opcao A, Opcao B)&#xa;            Entrada = MAX(R$150, R$333,33)&#xa;            Entrada = R$333,33&#xa;&#xa;  Por que? Garante que a entrada nao seja menor que 1 parcela." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="545" width="840" height="255" as="geometry"/>
        </mxCell>

        <!-- PASSO 4 -->
        <mxCell id="st4" value="PASSO 4: MONTAR NOVO PARCELAMENTO" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#a4286a;fontColor=#ffffff;rounded=1;strokeColor=#740037;" vertex="1" parent="1">
          <mxGeometry x="30" y="820" width="840" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="d4" value="FORMULA:&#xa;  Restante = Principal Total - Entrada&#xa;           = R$4.000 - R$333,33 = R$3.666,67&#xa;&#xa;  Parcelas restantes = 12 - 1 = 11  (entrada conta como 1a parcela)&#xa;&#xa;  Valor parcela = Restante / Parcelas restantes&#xa;               = R$3.666,67 / 11 = R$333,33&#xa;&#xa;  Validacao: parcela minima = R$50&#xa;  R$333,33 >= R$50? SIM!&#xa;&#xa;RESUMO DO NOVO CONTRATO:&#xa;  1x entrada de R$333,33 (paga na hora)&#xa;  + 11x parcelas de R$333,33&#xa;  = R$4.000,00 (principal)&#xa;  + R$60,00 (taxa de renegociacao)&#xa;  = R$4.060,00 total" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="30" y="855" width="840" height="310" as="geometry"/>
        </mxCell>

        <!-- RESULTADO -->
        <mxCell id="res" value="RESULTADO DO TESTE&#xa;&#xa;  Multa 2% de R$500 = R$10,00                PASSOU&#xa;  Juros 1%/mes, 90d, R$500 = R$15,00          PASSOU&#xa;  Juros 1%/mes, 60d, R$500 = R$10,00          PASSOU&#xa;  Juros 1%/mes, 30d, R$500 = R$5,00           PASSOU&#xa;  Taxa renegociacao = R$60,00                  PASSOU&#xa;  Entrada inteligente = R$333,33               PASSOU&#xa;  11 parcelas de R$333,33                      PASSOU&#xa;  Parcela >= R$50                              PASSOU" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=8;fontFamily=Courier New;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="890" y="680" width="600" height="200" as="geometry"/>
        </mxCell>

        <!-- BROWSER -->
        <mxCell id="bf" value="FLUXO NO PORTAL" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fillColor=#1a1a2e;fontColor=#FFFFFF;rounded=1;strokeColor=#16213e;" vertex="1" parent="1">
          <mxGeometry x="890" y="900" width="880" height="25" as="geometry"/>
        </mxCell>
