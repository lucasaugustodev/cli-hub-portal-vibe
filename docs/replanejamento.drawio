<mxfile host="draw.io">
  <diagram name="Replanejamento" id="replanejamento">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="t1" value="REPLANEJAMENTO FINANCEIRO" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fillColor=#1a1a2e;fontColor=#FFFFFF;rounded=1;strokeColor=#16213e;spacingTop=8;spacingBottom=8;" vertex="1" parent="1">
          <mxGeometry x="350" y="15" width="1100" height="50" as="geometry"/>
